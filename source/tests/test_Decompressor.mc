import Toybox.Lang;
import Toybox.Test;
import Toybox.WatchUi;
import Toybox.System;
import Toybox.Application;

// M10.0 tests for the byte-level-BPE + canonical-Huffman Decompressor (candidate
// E2) and the baked-model loader CompModel. The golden round-trip vectors at the
// bottom were generated by scripts/m10-compress/gen_model.py from the real
// top-1200 corpus and verified byte-exact by a Python watch-mirror decoder before
// this port. All vector data lives inside (:test) functions, so it is stripped
// from non-unit-test builds (zero release footprint).

// ---------------------------------------------------------------------------
// parseModel (pure decoder, source/models/Decompressor.mc)
// ---------------------------------------------------------------------------

(:test)
function parseModel_headerFields(logger as Logger) as Boolean {
    var res = WatchUi.loadResource($.Rez.JsonData.compModel) as Dictionary;
    var bytes = Decompressor.b64ToBytes(res["b64"] as String);
    var m = Decompressor.parseModel(bytes);
    if (m == null) { logger.error("parseModel returned null"); return false; }
    var V = m[:V] as Number;
    var mv = m[:modelVersion] as Number;
    var mcl = m[:maxCodeLen] as Number;
    // M10.1 flat model: per-token byte offsets into the resident mb (no 4096
    // materialized ByteArrays).
    var ts = m[:tokenStart] as Array;
    var mb = m[:mb] as ByteArray;
    logger.debug("V=" + V + " modelVersion=" + mv + " maxCodeLen=" + mcl
        + " tokenStart=" + ts.size() + " mb=" + mb.size());
    return V == 4096 && mv == 1 && mcl == 20 && ts.size() == 4096 && mb.size() == 36442;
}

(:test)
function decode_incrementalMatchesOneShot(logger as Logger) as Boolean {
    // M10.1: decoding the largest blob in small slices must equal the one-shot
    // decode (the read path slices to stay watchdog-safe).
    var model = CompModel.model();
    if (model == null) { logger.error("model null"); return false; }
    var blob = Decompressor.b64ToBytes("");
    var oneShot = Decompressor.decompress(blob, model as Dictionary);
    var st = Decompressor.decodeStart(Decompressor.b64ToBytes(""));
    var ticks = 0;
    while (!Decompressor.decodeStep(st, model as Dictionary, 100)) { ticks++; }
    var sliced = Decompressor.decodeText(st);
    logger.debug("oneShot len=" + oneShot.length() + " sliced len=" + sliced.length()
        + " ticks=" + ticks + " tokens=" + Decompressor.decodeTokenCount(st));
    return sliced.equals(oneShot) && oneShot.length() == 4263;
}

(:test)
function parseModel_rejectsBadMagic(logger as Logger) as Boolean {
    // 12 bytes of the wrong magic -> safe fallback (null), never garbage.
    var bad = [0x00, 0x01, 0x02, 0x03, 0, 1, 0, 1, 0x10, 0x00, 0x00, 0x14]b;
    var m = Decompressor.parseModel(bad);
    logger.debug("parseModel(bad magic) = " + m);
    return m == null;
}

// ---------------------------------------------------------------------------
// CompModel (impure baked-model loader, source/storage/CompModel.mc)
// ---------------------------------------------------------------------------

(:test)
function compModel_loadsAndVersion(logger as Logger) as Boolean {
    var m = CompModel.model();
    if (m == null) { logger.error("CompModel.model() null"); return false; }
    var baked = CompModel.bakedVersion();
    var mv = m[:modelVersion] as Number;
    logger.debug("bakedVersion=" + baked + " parsed modelVersion=" + mv);
    return baked == 1 && mv == 1;
}

(:test)
function compModel_decompressGuardedTiny(logger as Logger) as Boolean {
    // guarded production-style entry decodes the tiny vector. Compared against a
    // RAW Hebrew literal (not the base64 path) to independently confirm the bytes
    // -> UTF-8 String decode renders correct Hebrew.
    var got = CompModel.decompress(Decompressor.b64ToBytes("AAACL4tg"));
    logger.debug("CompModel.decompress tiny -> '" + got + "'");
    return got != null && got.equals("אבא");
}

// ---------------------------------------------------------------------------
// R2 evidence: decode + print a real Hebrew vector to monkeydo stdout, with the
// live freeMemory after the decode.
// ---------------------------------------------------------------------------

(:test)
function decompress_r2_printAba(logger as Logger) as Boolean {
    var model = CompModel.model();
    if (model == null) { logger.error("model null"); return false; }
    var blob = Decompressor.b64ToBytes("AAACL4tg");
    var got = Decompressor.decompress(blob, model as Dictionary);
    var want = Decompressor.b64ToString("15DXkdeQ");
    logger.debug("R2 decode tiny -> '" + got + "' match=" + got.equals(want)
        + " free=" + System.getSystemStats().freeMemory);
    return got.equals(want);
}

// ---------------------------------------------------------------------------
// Golden round-trip vectors (auto-generated; see gen_model.py). Spread of sizes
// from 6 B up to the largest article (7680 B = worst-case decode).
// ---------------------------------------------------------------------------

(:test)
function decompressGolden_tiny_aba(logger as Logger) as Boolean {
    var model = CompModel.model();
    if (model == null) { logger.error("model() returned null"); return false; }
    var blob = Decompressor.b64ToBytes("AAACL4tg");
    var want = Decompressor.b64ToString("15DXkdeQ");
    var got = Decompressor.decompress(blob, model as Dictionary);
    logger.debug("id=tiny-aba got=" + got.length() + " want=" + want.length());
    return got.equals(want);
}

